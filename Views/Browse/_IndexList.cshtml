@model BrowseDirectoryViewModel

@if (Model.Directories.Any())
{
    <ul class="file-list">
        @foreach (var dir in Model.Directories)
        {
            <li>
                <svg bootstrap-icon="Folder" width="24" height="24" aria-label="Folder"></svg><a
                href="@Url.Action("Index", "Browse", new {share = dir.Share, path = dir.Path, view = dir.ViewType})">@dir.Name</a>
            </li>
        }
    </ul>
}

@if (Model.Files.Any(f => f.IsVideo))
{
    <ul class="file-list">
        @foreach (var file in Model.Files.Where(f => f.IsVideo))
        {

            <li><a asp-controller="Browse" asp-action="ViewVideo" asp-route-share="@file.Share"
                       asp-route-path="@file.Path">@file.Name</a></li>
        }
    </ul>
}

@if (Model.Files.Any(f => f.IsImage))
{
    <ul class="file-list">
        @foreach (var file in Model.Files.Where(f => f.IsImage))
        {
            <li><a asp-controller="Browse" asp-action="ViewImages" asp-route-share="@Model.Share" asp-route-path="@Model.Path"
                        asp-route-image="@file.Name">@file.Name</a></li>
        }
    </ul>
}

@if (Model.Files.Any(f => !f.IsImage && !f.IsVideo))
{
    <ul class="file-list">
        @foreach (var file in Model.Files.Where(f => !f.IsImage && !f.IsVideo))
        {
            <li>@file.Name</li>
        }
    </ul>
}